# ===========================================
# GDP (Generative Digital-twin Prototyper)
# ===========================================

# --- LLM API Keys (at least one required) ---
# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Model Configuration ---
# Default model for BOP generation / modification / chat
DEFAULT_MODEL=gemini-2.5-flash

# Default model for tool adapter generation
DEFAULT_TOOL_MODEL=gemini-2.0-flash

# Available models in the UI (format: model_id|Display Name, ...)
SUPPORTED_MODELS=gemini-2.5-flash|Gemini 2.5 Flash,gemini-2.0-flash|Gemini 2.0 Flash,gpt-4o|GPT-4o,gpt-4o-mini|GPT-4o Mini,gpt-5-mini|GPT-5 Mini
